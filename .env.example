# BESTEAMHN Frontend environment variables
# Copy this file to `.env` and fill in your own values.
# Do not commit `.env` to GitHub.

# Supabase project URL.
# Example: https://your-project-ref.supabase.co
VITE_SUPABASE_URL=

# Supabase anon/public key used by the browser client.
# This is safe to expose in the frontend, but RLS policies must protect your data.
VITE_SUPABASE_ANON_KEY=

# Solana Devnet SPL token mint address for STEAM rewards.
# This token/mint was deployed from Solana Playground.
VITE_STEAM_MINT_ADDRESS=

# Supabase Edge Function secrets, configured in Supabase, not in Vite:
# GEMINI_API_KEY=           # Used by supabase/functions/ai-tutor
# STEAM_MINT_ADDRESS=       # Same mint address used by supabase/functions/mint-steam
# STEAM_MINT_AUTHORITY=     # Base64-encoded Solana mint authority secret key
